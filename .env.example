# Ballad Phase 2a 模型配置
# 复制此文件为 .env，按实际情况填写。Bun 原生自动加载 .env，无需 dotenv。
#
# 多模型注册表（前缀式分组）：
#   MODELS_<NAME>_PROTOCOL = anthropic | openai-v1 | openai-v2 | mock
#   MODELS_<NAME>_MODEL    = 厂商 model id
#   MODELS_<NAME>_BASE_URL = (可选) 自定义端点 / 内网网关
#   MODELS_<NAME>_API_KEY  = (可选) 鉴权 key
# <NAME> 是模型实例标识，小写后作为运行时切换用的 name。
# 同一协议下可有多个实例——适配器代码不分支，只在配置里区分。

# ---- GLM (openai-v1 兼容内网网关) ----
MODELS_GLM_PROTOCOL=openai-v1
MODELS_GLM_MODEL=z-ai/glmi-5.2
MODELS_GLM_BASE_URL=https://llm.api.zyuncs.com/v1
MODELS_GLM_API_KEY=sk-...

# ---- DeepSeek (同样 openai-v1 兼容，复用同一适配器) ----
# MODELS_DEEPSEEK_PROTOCOL=openai-v1
# MODELS_DEEPSEEK_MODEL=deepseek-v4-pro
# MODELS_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# MODELS_DEEPSEEK_API_KEY=sk-...

# ---- 官方 OpenAI ----
# MODELS_OPENAI_PROTOCOL=openai-v1
# MODELS_OPENAI_MODEL=gpt-4o
# MODELS_OPENAI_API_KEY=sk-...
# (BASE_URL 不填走官方默认)

# ---- Anthropic (后续适配器就位后启用) ----
# MODELS_CLAUDE_PROTOCOL=anthropic
# MODELS_CLAUDE_MODEL=claude-sonnet-4-5
# MODELS_CLAUDE_API_KEY=sk-ant-...

# ---- 激活模型 ----
# 指定运行时使用的模型 name。不设则自动选第一个；一个真实模型都没有则回落 mock。
BALLAD_ACTIVE_MODEL=glm
