{
  "name": "ballad",
  "version": "0.1.0",
  "description": "Coding Agent TUI — 脑口分离架构",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests",
    "test:core": "bun test tests/core",
    "test:tui": "bun test tests/tui",
    "test:arch": "bun test tests/arch",
    "test:e2e": "bash tests/e2e/smoke.sh",
    "compile": "bun build --compile src/index.ts --outfile dist/agent"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.12",
    "bun-types": "^1.3.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.3"
  }
}
